<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pink Travel - Itinerar</title>
    <style>
        body { background-color: #FFF5F8; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; color: #4A4A4A; }
        .container { max-width: 900px; margin: 0 auto; background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(255, 182, 193, 0.3); border: 2px solid #FFC0CB; }
        .header { text-align: center; border-bottom: 2px dashed #FFB6C1; padding-bottom: 20px; margin-bottom: 30px; }
        .header h1 { color: #FF69B4; margin: 0; font-size: 2.5em; text-transform: uppercase; letter-spacing: 2px; }
        
        .stats-grid { background: #FFF9FA; padding: 15px; border-radius: 15px; margin-bottom: 30px; text-align: center; }
        .stat-value { display: block; font-size: 1.5em; font-weight: bold; color: #FF1493; }
        .stat-label { font-size: 0.8em; color: #888; text-transform: uppercase; }

        h2 { color: #FF69B4; border-left: 5px solid #FF69B4; padding-left: 15px; margin-bottom: 20px; }
        table { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
        th { background: #FFB6C1; color: white; padding: 15px; text-align: left; text-transform: uppercase; font-size: 0.9em; border-radius: 10px; }
        
        td { padding: 15px; background: #fff; border-top: 1px solid #FFE4E1; border-bottom: 1px solid #FFE4E1; }
        tr td:first-child { border-left: 1px solid #FFE4E1; border-radius: 10px 0 0 10px; font-weight: bold; }
        tr td:last-child { border-right: 1px solid #FFE4E1; border-radius: 0 10px 10px 0; text-align: center; }

        .details-row { display: none; background: #FFF9FA !important; }
        .details-row td { border: 1px solid #FFB6C1 !important; border-radius: 10px; padding: 20px; }
        .details-content { display: flex; justify-content: space-between; align-items: center; }

        .btn-detalii { background: #FF69B4; color: white; border: none; padding: 10px 20px; border-radius: 20px; font-size: 0.9em; cursor: pointer; transition: 0.3s; }
        .btn-detalii:hover { background: #FF1493; transform: scale(1.05); }
        
        .link-extern { color: #FF1493; font-weight: bold; text-decoration: none; border-bottom: 1px solid #FF1493; }
        .link-extern:hover { color: #4A4A4A; border-color: #4A4A4A; }

        .footer-nav { margin-top: 40px; text-align: center; }
        .btn-logout { color: #888; text-decoration: none; font-size: 0.9em; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Pink Travel</h1>
        </div>

        <div class="stats-grid">
            <span class="stat-value"><%= (typeof lastVisited !== 'undefined') ? lastVisited : 'Niciuna' %></span>
            <span class="stat-label">Ultima Destinatie Vizualizata</span>
        </div>

        <h2>Destinatii Populare</h2>
        <table>
            <thead>
                <tr>
                    <th>Locatie</th>
                    <th>Regiune</th>
                    <th>Actiune</th>
                </tr>
            </thead>
            <tbody>
                <!-- PARIS -->
                <tr>
                    <td>Paris</td>
                    <td>Europa / Franta</td>
                    <td><button class="btn-detalii" onclick="toggleDetails('paris', 'Paris')">Vezi Detalii</button></td>
                </tr>
                <tr id="details-paris" class="details-row">
                    <td colspan="3">
                        <div class="details-content">
                            <span>Pret: <b>500 EUR</b></span>
                            <a href="https://destinationlesstravel.com/best-things-to-do-in-paris/" target="_blank" class="link-extern">Deschide Ghid Turistic</a>
                        </div>
                    </td>
                </tr>

                <!-- MALDIVE -->
                <tr>
                    <td>Maldive</td>
                    <td>Asia / Oceanul Indian</td>
                    <td><button class="btn-detalii" onclick="toggleDetails('maldive', 'Maldive')">Vezi Detalii</button></td>
                </tr>
                <tr id="details-maldive" class="details-row">
                    <td colspan="3">
                        <div class="details-content">
                            <span>Pret: <b>1200 EUR</b></span>
                            <a href="https://www.visitmaldives.com" target="_blank" class="link-extern">Deschide Ghid Turistic</a>
                        </div>
                    </td>
                </tr>

                <!-- SARDINIA -->
                <tr>
                    <td>Sardinia</td>
                    <td>Europa / Italia</td>
                    <td><button class="btn-detalii" onclick="toggleDetails('sardinia', 'Sardinia')">Vezi Detalii</button></td>
                </tr>
                <tr id="details-sardinia" class="details-row">
                    <td colspan="3">
                        <div class="details-content">
                            <span>Pret: <b>800 EUR</b></span>
                            <a href="https://www.sardegnaturismo.it" target="_blank" class="link-extern">Deschide Ghid Turistic</a>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="footer-nav">
            <a href="/logout" class="btn-logout">Deconectare (Logout)</a>
        </div>
    </div>

    <script>
        function toggleDetails(id, nume) {
            const row = document.getElementById('details-' + id);
            
            // Inchide alte randuri deschise
            document.querySelectorAll('.details-row').forEach(r => {
                if(r.id !== 'details-' + id) r.style.display = 'none';
            });

            // Toggle randul curent
            if (row.style.display === 'table-row') {
                row.style.display = 'none';
            } else {
                row.style.display = 'table-row';
                
                // Trimite cerere la server pentru a actualiza "Ultima Destinatie" fara sa reincarce pagina
                fetch('/travel/update-last-visited/' + nume);
            }
        }
    </script>
</body>
</html>